# ============================================================
# Knowledge Maker - 環境変数設定例
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# AI プロバイダー設定（いずれか1つを設定）
# 優先順位: OpenAI > AWS Bedrock > Anthropic > Azure OpenAI
# ------------------------------------------------------------

# --- Option 1: AWS Bedrock (Bearer Token) ---
# AWS_BEARER_TOKEN_BEDROCK=bedrock-api-key-xxxxxxxxxxxxxxxx
# AWS_DEFAULT_REGION=us-east-1
#
# Chat / Vision でリージョンを分ける場合（省略時は AWS_DEFAULT_REGION を使用）:
# AWS_DEFAULT_REGION_CHAT=ap-northeast-1
# AWS_DEFAULT_REGION_VISION=us-east-1
#
# Chat / Vision でトークンを分ける場合（省略時は AWS_BEARER_TOKEN_BEDROCK を使用）:
# AWS_BEARER_TOKEN_BEDROCK_CHAT=bedrock-api-key-yyy
# AWS_BEARER_TOKEN_BEDROCK_VISION=bedrock-api-key-zzz
#
# モデル ID（省略時のデフォルト: jp.anthropic.claude-sonnet-4-6）:
# BEDROCK_ENHANCE_MODEL=us.anthropic.claude-sonnet-4-6
# BEDROCK_VISION_MODEL=us.anthropic.claude-sonnet-4-6
#
# モデル ID プレフィックス例:
#   us.anthropic.claude-sonnet-4-6      (US リージョン: us-east-1)
#   jp.anthropic.claude-sonnet-4-6      (東京リージョン: ap-northeast-1)
#   global.anthropic.claude-opus-4-6-v1 (Global)

# --- Option 2: OpenAI ---
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
# OPENAI_ENHANCE_MODEL=gpt-5.1
# OPENAI_VISION_MODEL=gpt-5-mini

# --- Option 3: Anthropic (direct) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# ANTHROPIC_ENHANCE_MODEL=claude-sonnet-4-6
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# --- Option 4: Azure OpenAI ---
# AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT_CHAT=gpt5.1
# AZURE_OPENAI_DEPLOYMENT_VISION=gpt5-mini
#
# Chat / Vision でキーを分ける場合（省略時は AZURE_OPENAI_API_KEY を使用）:
# AZURE_OPENAI_API_KEY_CHAT=xxxxxxxx
# AZURE_OPENAI_API_KEY_VISION=xxxxxxxx

# ------------------------------------------------------------
# 並列処理設定
# ------------------------------------------------------------
VISION_API_PARALLEL_WORKERS=30
ENHANCE_DOCUMENT_PARALLEL_WORKERS=30

# ------------------------------------------------------------
# ドキュメント変換設定
# ------------------------------------------------------------
# ENABLE_IMAGE_EXTRACTION=true
# ENABLE_IMAGE_AI_DESCRIPTION=true
# IMAGE_MAX_WIDTH=1200

# ------------------------------------------------------------
# システム設定
# ------------------------------------------------------------
KM_SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# HTTPS_PROXY=http://proxy.example.com:8080
